# ─── Telegram Bot ───────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── Storage (optional, mặc định dùng ./data/) ──────────────────────────────
# STATE_FILE=./data/state.json
# HISTORY_FILE=./data/history.json

# ─── Entrypoint action ──────────────────────────────────────────────────────
# ACTION=monitor          → chạy monitor giá vàng một lần
# ACTION=daily-report     → gửi báo cáo 24h một lần
# (GitHub Actions tự set biến này qua env: block trong workflow)
ACTION=monitor

# ─── Debug ──────────────────────────────────────────────────────────────────
# DEBUG=false